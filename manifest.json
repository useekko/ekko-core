{
  "manifest_version": 3,
  "name": "Ekko",
  "version": "0.7.0",
  "description": "Private, post-quantum encrypted messaging on top of the apps you already use. Your keys never leave your device.",
  "minimum_chrome_version": "138",
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Ekko",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.instagram.com/*"
      ],
      "js": [
        "instagram.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://web.whatsapp.com/*"
      ],
      "js": [
        "whatsapp.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://web.telegram.org/*"
      ],
      "js": [
        "telegram.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://www.messenger.com/*"
      ],
      "js": [
        "messenger.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://account.useekko.app/*"
      ],
      "js": [
        "account-bridge.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "permissions": [
    "storage",
    "activeTab",
    "scripting"
  ],
  "commands": {
    "seal-anywhere": {
      "suggested_key": {
        "default": "Ctrl+Shift+E",
        "mac": "Command+Shift+E"
      },
      "description": "Seal the message you're writing for an Ekko contact"
    }
  },
  "host_permissions": [
    "https://useekko.app/*",
    "https://hkcohnjgyutarjoongbb.supabase.co/*"
  ]
}
