{
  "name": "ekko",
  "private": true,
  "license": "GPL-3.0-only",
  "description": "Device-owned post-quantum encryption layer over existing messenger web UIs",
  "type": "module",
  "scripts": {
    "icons": "node scripts/make-icons.mjs",
    "build": "node scripts/make-icons.mjs && node esbuild.mjs",
    "dev": "node esbuild.mjs --watch",
    "package": "npm run build && node scripts/package.mjs",
    "package:firefox": "npm run build && node scripts/package.mjs --firefox",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "ios:safari": "npm run build && node scripts/ios-safari-sync.mjs"
  },
  "dependencies": {
    "@noble/ciphers": "^1.2.1",
    "@noble/curves": "^1.8.1",
    "@noble/hashes": "^1.7.1",
    "@noble/post-quantum": "^0.4.0",
    "@scure/bip39": "^1.6.0",
    "qr": "^0.6.0",
    "qrcode": "^1.5.4"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.313",
    "@types/qrcode": "^1.5.5",
    "esbuild": "^0.25.0",
    "jsdom": "^29.1.1",
    "typescript": "^5.7.3",
    "vitest": "^3.0.5"
  }
}
